{
  "nodes": [
    {
      "id": "ResearchStudyCollection",
      "label": "ResearchStudyCollection",
      "abstract": false,
      "description": "A holder for ResearchStudy objects"
    },
    {
      "id": "ResearchStudy",
      "label": "ResearchStudy",
      "abstract": false,
      "description": "A process where a researcher or organization plans and then executes a series of steps intended to increase the field of healthcare-related knowledge. This includes studies of safety, efficacy, comparative effectiveness and other information about medications, devices, therapies and other interventional and investigative techniques. A ResearchStudy involves the gathering of information about human or animal subjects."
    },
    {
      "id": "TimePoint",
      "label": "TimePoint",
      "abstract": false,
      "description": "A structured representation of a single point in time that allows direct/explicit declaration as a dateTime, specification in terms of offset from a defined index, or description of an event type as a proxy for the time point when it occurred."
    },
    {
      "id": "Consent",
      "label": "Consent",
      "abstract": false,
      "description": "An entity that can be used to capture consent code and other relevant data about consent for a study."
    },
    {
      "id": "Participant",
      "label": "Participant",
      "abstract": false,
      "description": "A Participant is the entity of interest in a research study, typically a human being or an animal, but can also be a device, group of humans or animals, or a tissue sample. Human research subjects are usually not traceable to a particular person to protect the subject\u2019s privacy."
    },
    {
      "id": "Demography",
      "label": "Demography",
      "abstract": false,
      "description": "Demographics about an individual or animal receiving care or other health-related services."
    },
    {
      "id": "Visit",
      "label": "Visit",
      "abstract": false,
      "description": "Events where Persons engage with the healthcare system for a duration of time. They are often also called \u201cEncounters\u201d. Visits are defined by a configuration of circumstances under which they occur, such as (i) whether the patient comes to a healthcare institution, the other way around, or the interaction is remote, (ii) whether and what kind of trained medical staff is delivering the service during the Visit, and (iii) whether the Visit is transient or for a longer period involving a stay in bed. (OMOP)"
    },
    {
      "id": "QuestionnaireResponse",
      "label": "QuestionnaireResponse",
      "abstract": false,
      "description": "QuestionnaireResponse provides a complete or partial list of answers to a set of questions filled when responding to a questionnaire. (FHIR)"
    },
    {
      "id": "QuestionnaireResponseItem",
      "label": "QuestionnaireResponseItem",
      "abstract": false,
      "description": "QuestionnaireResponseItem provides a complete or partial list of answers to a set of questions filled when responding to a questionnaire. (FHIR)"
    },
    {
      "id": "QuestionnaireResponseValue",
      "label": "QuestionnaireResponseValue",
      "abstract": true,
      "description": "Single-valued answer to the question. (FHIR)"
    },
    {
      "id": "QuestionnaireResponseValueBoolean",
      "label": "QuestionnaireResponseValueBoolean",
      "abstract": false,
      "description": "Single-valued boolean answer to the question"
    },
    {
      "id": "QuestionnaireResponseValueDecimal",
      "label": "QuestionnaireResponseValueDecimal",
      "abstract": false,
      "description": "Single-valued decimal answer to the question"
    },
    {
      "id": "QuestionnaireResponseValueInteger",
      "label": "QuestionnaireResponseValueInteger",
      "abstract": false,
      "description": "Single-valued integer answer to the question"
    },
    {
      "id": "QuestionnaireResponseValueString",
      "label": "QuestionnaireResponseValueString",
      "abstract": false,
      "description": "Single-valued string answer to the question"
    },
    {
      "id": "QuestionnaireResponseValueTimePoint",
      "label": "QuestionnaireResponseValueTimePoint",
      "abstract": false,
      "description": "Single-valued TimePoint answer to the question"
    },
    {
      "id": "Condition",
      "label": "Condition",
      "abstract": false,
      "description": "Conditions are records of a Person suggesting the presence of a disease or medical condition stated as a diagnosis, a sign or a symptom, which is either observed by a Provider or reported by the patient. Conditions are recorded in different sources and levels of standardization."
    },
    {
      "id": "Procedure",
      "label": "Procedure",
      "abstract": false,
      "description": "Procedure contains records of activities or processes ordered by, or carried out by, a healthcare provider on the patient to have a diagnostic or therapeutic purpose. Procedures are present in various data sources in different forms with varying levels of standardization. [Derived from OMOP]"
    },
    {
      "id": "Quantity",
      "label": "Quantity",
      "abstract": false,
      "description": "A structured object to represent an amount of something (e.g., weight, mass, length, duration of time) - including a value and unit."
    },
    {
      "id": "ImagingStudy",
      "label": "ImagingStudy",
      "abstract": false,
      "description": "An ImagingStudy is a set of images produced in a single study (one or more series of references images).  It may include images from different modalities (e.g. CT, MR, Ultrasound) and from different instances in time.  The ImagingStudy may be linked to other information such as the clinical context in which the images were acquired."
    },
    {
      "id": "BodySite",
      "label": "BodySite",
      "abstract": false,
      "description": "A site in the body of an organism, typically described in terms of an anatomical concept and optional qualifiers (e.g. left/right, upper/lower). But body sites as defined here may include non-canonical sites, such as an implanted medical device."
    },
    {
      "id": "Exposure",
      "label": "Exposure",
      "abstract": false,
      "description": "Exposures are records of a Person suggesting exposure to a medication, device, environmental material."
    },
    {
      "id": "DeviceExposure",
      "label": "DeviceExposure",
      "abstract": false,
      "description": "DeviceExposures are records of a Person suggesting exposure to a foreign object. The source is typically physical objects used in procedures, measurements, or observations."
    },
    {
      "id": "DrugExposure",
      "label": "DrugExposure",
      "abstract": false,
      "description": "DrugExposures are records of a Person suggesting exposure to a medication. The source could be prescription, dispensing, medication administration records (MARs), or patient medication list."
    },
    {
      "id": "ObservationSet",
      "label": "ObservationSet",
      "abstract": false,
      "description": "A structured object to hold related Observations in a set."
    },
    {
      "id": "Observation",
      "label": "Observation",
      "abstract": false,
      "description": "A data structure with key (observation_type) and value (value) attributes that represents a single observation, such as the hematocrit component of a complete blood count panel."
    },
    {
      "id": "Organization",
      "label": "Organization",
      "abstract": false,
      "description": "A grouping of people or organizations with a common purpose such as a data coordinating center, an university, or an institute within a university."
    },
    {
      "id": "DimensionalObservation",
      "label": "DimensionalObservation",
      "abstract": false,
      "description": "A structured object that describes a single data item about the physical dimensions of an entity (e.g. length width, area), as generated through a point-in-time observation or measurement."
    },
    {
      "id": "MeasurementObservation",
      "label": "MeasurementObservation",
      "abstract": false,
      "description": "A data structure with key (observation_type) and value (value) attributes that represents a single observation, such as the hematocrit component of a complete blood count panel."
    },
    {
      "id": "Assay",
      "label": "Assay",
      "abstract": false,
      "description": "A class for representing metadata about an assay performed on a specimen, including the method and instrument used."
    },
    {
      "id": "Substance",
      "label": "Substance",
      "abstract": false,
      "description": "A type of material substance, or instance thereof, as used in a particular application. May include information about the role the substance played in a particular application."
    },
    {
      "id": "SdohObservation",
      "label": "SdohObservation",
      "abstract": false,
      "description": "A data structure with key (observation_type) and value (value) attributes that represents a single observation, such as the hematocrit component of a complete blood count panel."
    },
    {
      "id": "QuestionnaireItem",
      "label": "QuestionnaireItem",
      "abstract": false,
      "description": "QuestionnaireItem defines a question or section within the Questionnaire"
    },
    {
      "id": "SpecimenQualityObservation",
      "label": "SpecimenQualityObservation",
      "abstract": false,
      "description": "A structured object that describes a characteristic of a specimen indicative of its quality or suitability for use, as generated through a point-in-time observation or measurement."
    },
    {
      "id": "SpecimenQuantityObservation",
      "label": "SpecimenQuantityObservation",
      "abstract": false,
      "description": "A structured object that describes a single data item about the quantity of a Specimen, as generated through a point-in-time observation or measurement."
    },
    {
      "id": "DimensionalObservationSet",
      "label": "DimensionalObservationSet",
      "abstract": false,
      "description": "A set of one or more discrete observations about the physical dimensions of an object (e.g. length, width, area)."
    },
    {
      "id": "MeasurementObservationSet",
      "label": "MeasurementObservationSet",
      "abstract": false,
      "description": "A structured object to hold related Observations in a set."
    },
    {
      "id": "SdohObservationSet",
      "label": "SdohObservationSet",
      "abstract": false,
      "description": "A structured object to hold related Observations in a set."
    },
    {
      "id": "File",
      "label": "File",
      "abstract": false,
      "description": "Abstract class for various kinds of files. Subclasses may be defined for specific file types."
    },
    {
      "id": "ImagingFile",
      "label": "ImagingFile",
      "abstract": false,
      "description": "A file that contains diagnostic imaging data, such as a DICOM file, or a JPEG or PNG image."
    },
    {
      "id": "Person",
      "label": "Person",
      "abstract": false,
      "description": "Administrative information about an individual or animal receiving care or other health-related services."
    },
    {
      "id": "CauseOfDeath",
      "label": "CauseOfDeath",
      "abstract": false,
      "description": "A class / complex datatype for handling both values and ordinality for causes of death."
    },
    {
      "id": "Specimen",
      "label": "Specimen",
      "abstract": false,
      "description": "Any material taken as a sample from a biological entity (living or dead), or from a physical object or the environment. Specimens are usually collected as an example of their kind, often for use in some investigation."
    },
    {
      "id": "SpecimenContainer",
      "label": "SpecimenContainer",
      "abstract": false,
      "description": "A vessel in which a specimen is held or to which it is attached - for storage or as a substrate for growth (e.g. a cell culture dish) or analysis (e.g. a microscope slide or 96-well plate)"
    },
    {
      "id": "SpecimenCreationActivity",
      "label": "SpecimenCreationActivity",
      "abstract": false,
      "description": "The process of creating a specimen. This may occur through observing and/or collecting material from an biological source or natural setting, or through derivation from an existing specimen (e.g. via portioning or aliquoting)."
    },
    {
      "id": "BiologicProduct",
      "label": "BiologicProduct",
      "abstract": false,
      "description": "A living organism, or a metabolically active biological system such as a cell culture, tissue culture, or organoid that is maintained or propagated in vitro."
    },
    {
      "id": "SpecimenProcessingActivity",
      "label": "SpecimenProcessingActivity",
      "abstract": false,
      "description": "An activity that modifies the physical structure, composition, or state of a specimen. Unlike SpecimenCreation, SpecimenProcessing activities do not result in the generation of new entities - they take a single specimen as input, and output that same specimen."
    },
    {
      "id": "Document",
      "label": "Document",
      "abstract": false,
      "description": "A collection of information intented to be understood together as a whole, and codified in human-readable form."
    },
    {
      "id": "SpecimenStorageActivity",
      "label": "SpecimenStorageActivity",
      "abstract": false,
      "description": "An activity in which a specimen is stored or maintained in a particular location, container, or state. Unlike 'processing' activities, storage does not alter the \\nintrinsic physical nature of a specimen."
    },
    {
      "id": "SpecimenTransportActivity",
      "label": "SpecimenTransportActivity",
      "abstract": false,
      "description": "An activity through which a specimen is transported between locations or organizations."
    }
  ],
